# =============================================================================
# SkyMetron — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit real secrets to version control.
# =============================================================================

# --- Database (PostgreSQL) ---
POSTGRES_DB=skymetron
POSTGRES_USER=skymetron
POSTGRES_PASSWORD=<generate-a-strong-password>
SKY_DB_HOST=localhost
SKY_DB_PORT=5432
SKY_DB_NAME=skymetron
SKY_DB_USER=${POSTGRES_USER}
SKY_DB_PASSWORD=${POSTGRES_PASSWORD}

# --- Redis ---
SKY_REDIS_HOST=localhost
SKY_REDIS_PORT=6379

# --- RabbitMQ ---
RABBITMQ_USER=skymetron
RABBITMQ_PASSWORD=<generate-a-strong-password>
SKY_RABBIT_HOST=localhost
SKY_RABBIT_PORT=5672
SKY_RABBIT_USER=${RABBITMQ_USER}
SKY_RABBIT_PASSWORD=${RABBITMQ_PASSWORD}

# --- Security ---
SKY_JWT_SECRET=<generate-a-32-byte-random-secret>
SKY_ENCRYPTION_KEY=<generate-a-32-byte-base64-key>

# --- GitHub OAuth (required for authentication) ---
SKY_GITHUB_CLIENT_ID=<your-github-oauth-app-client-id>
SKY_GITHUB_CLIENT_SECRET=<your-github-oauth-app-client-secret>

# --- CORS ---
SKY_CORS_ORIGINS=http://localhost:5173,capacitor://localhost,http://localhost

# --- AI Services ---
SKY_AI_SERVICES_URL=http://localhost:8001
SKY_OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
SKY_EMBEDDING_MODEL=nomic-embed-text
SKY_OLLAMA_CHAT_MODEL=llama3.1:8b

# --- LLM Provider API Keys (at least one required for cloud providers) ---
SKY_PROVIDERS_GOOGLE_API-KEY=<your-google-api-key>
SKY_PROVIDERS_MISTRAL_API-KEY=<your-mistral-api-key>
SKY_PROVIDERS_NVIDIA_API-KEY=<your-nvidia-api-key>
SKY_PROVIDERS_OPENROUTER_API-KEY=<your-openrouter-api-key>
SKY_PROVIDERS_GROQ_API-KEY=<your-groq-api-key>
SKY_PROVIDERS_CEREBRAS_API-KEY=<your-cerebras-api-key>
SKY_PROVIDERS_MINIMAX_API-KEY=<your-minimax-api-key>

# --- Desktop (optional) ---
VITE_API_BASE_URL=http://localhost:8080
