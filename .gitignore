# =============================================================================
# SkyMetron — root .gitignore
# Covers: Java/Maven, Python, Node/Electron, Docker, IDE, secrets, runtime data
# =============================================================================

# --- Legacy archive (has its own git, kept read-only) ---
/ENIAC_METRON/

# --- Secrets / environment ---
.env
.env.*
*.local
!.env.example
*.pem
*.key
*.p12
*.keystore
secrets/
**/application-secret*.yml

# --- Java / Maven ---
**/target/
**/.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*
.mvn/timing.properties
.mvn/wrapper/MavenWrapperDownloader.java

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
.eggs/
dist/
build/
!sky-desktop/build/
!sky-desktop/build/legal/
!sky-desktop/build/legal/**
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# --- Node / Electron / Frontend ---
node_modules/
dist/
.vite/
.next/
.nuxt/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.turbo/
.parcel-cache/

# --- Docker runtime ---
docker/data/
docker/volumes/

# --- Runtime data: logs, cache, embeddings, vault, backups ---
logs/
**/logs/
*.log
cache/
**/cache/
embeddings/
**/embeddings/*.bin
**/embeddings/*.npy
vault/
backups/
*.backup
*.bak
*.dump
*.sql.gz

# --- Observability runtime ---
prometheus/data/
grafana/data/
loki/data/

# --- IDE ---
.idea/
*.iml
*.ipr
*.iws
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
*~
.project
.classpath
.settings/
.factorypath
*.sublime-workspace
*.sublime-project

# --- Obsidian ---
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# --- OS ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Test reports ---
**/surefire-reports/
**/failsafe-reports/
**/site/
test-results/

# Other SkyMetron repos (siblings, not submodules)
/sky-vault/
/skymetron-ai-services/
/skymetron-deployment/
/skymetron-docs/
/skymetron-monitoring/
/skymetron-secrets/
/skymetron-vault/
